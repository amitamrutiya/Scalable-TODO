# Production Environment - Amazon RDS
# Copy this to .env and fill in the auth token

# Server Configuration
PORT=3000
NODE_ENV=production

# Amazon RDS Configuration
# Generate token with:
#   aws rds generate-db-auth-token --hostname database-2.cluster-c4v8260a8z2i.us-east-1.rds.amazonaws.com --port 5432 --username postgres --region us-east-1
DATABASE_URL=postgresql://postgres:AUTH_TOKEN@database-2.cluster-c4v8260a8z2i.us-east-1.rds.amazonaws.com:5432/todoapp?sslmode=require

# JWT Configuration (GENERATE NEW SECRET!)
# openssl rand -base64 48
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-long-for-security
JWT_EXPIRES_IN=15m

# Password Hashing
BCRYPT_ROUNDS=12

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info